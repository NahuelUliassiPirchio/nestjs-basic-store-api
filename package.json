{
   "name": "basic-store",
   "version": "1.0.1",
   "description": "",
   "author": "Nahuel Uliassi Pirchio",
   "private": true,
   "license": "UNLICENSED",
   "engines": {
      "node": "24.x"
   },
   "scripts": {
      "prebuild": "rimraf dist",
      "build": "nest build",
      "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
      "start": "nest start",
      "dev": "nest start --watch",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node dist/main",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
      "typeorm": "typeorm-ts-node-commonjs",
      "migration:generate": "npm run typeorm migration:generate -d src/database/dataSource.ts",
      "migration:generates": "npx typeorm-ts-node-commonjs migration:generate ./src/database/migrations/init -d ./src/database/dataSource.ts"
   },
   "dependencies": {
      "@nestjs/common": "^11.1.19",
      "@nestjs/config": "^4.0.4",
      "@nestjs/core": "^11.1.19",
      "@nestjs/jwt": "^11.0.2",
      "@nestjs/mapped-types": "^2.1.1",
      "@nestjs/passport": "^11.0.5",
      "@nestjs/platform-express": "^11.1.19",
      "@nestjs/swagger": "^11.4.2",
      "@nestjs/throttler": "^6.5.0",
      "@nestjs/typeorm": "^11.0.1",
      "bcrypt": "^6.0.0",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.15.1",
      "cors": "^2.8.6",
      "helmet": "^8.1.0",
      "passport": "^0.7.0",
      "passport-jwt": "^4.0.1",
      "passport-local": "^1.0.0",
      "pg": "^8.20.0",
      "reflect-metadata": "^0.2.2",
      "rimraf": "^6.1.3",
      "rxjs": "^7.8.2",
      "typeorm": "^0.3.28"
   },
   "devDependencies": {
      "@nestjs/cli": "^11.0.21",
      "@nestjs/schematics": "^11.1.0",
      "@nestjs/testing": "^11.1.19",
      "@types/bcrypt": "^6.0.0",
      "@types/express": "^5.0.6",
      "@types/jest": "^29.5.14",
      "@types/node": "^24.0.0",
      "@types/passport-jwt": "^4.0.1",
      "@types/passport-local": "^1.0.38",
      "@types/pg": "^8.20.0",
      "@types/supertest": "^7.2.0",
      "@typescript-eslint/eslint-plugin": "^8.59.1",
      "@typescript-eslint/parser": "^8.59.1",
      "eslint": "^8.57.1",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-prettier": "^5.5.5",
      "jest": "^29.7.0",
      "prettier": "^3.8.3",
      "source-map-support": "^0.5.21",
      "supertest": "^7.2.2",
      "ts-jest": "^29.4.9",
      "ts-loader": "^9.5.7",
      "ts-node": "^10.9.2",
      "tsconfig-paths": "^4.2.0",
      "typescript": "^5.9.3"
   },
   "jest": {
      "moduleFileExtensions": [
         "js",
         "json",
         "ts"
      ],
      "rootDir": "src",
      "testRegex": ".*\\.spec\\.ts$",
      "transform": {
         "^.+\\.(t|j)s$": "ts-jest"
      },
      "collectCoverageFrom": [
         "**/*.(t|j)s"
      ],
      "coverageDirectory": "../coverage",
      "testEnvironment": "node"
   },
   "overrides": {
      "typeorm": {
         "uuid": "14.0.0"
      }
   }
}
